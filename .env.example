# Copy to .env.local (local dev) or .env.production (Hostinger VPS).
# Never commit real secrets.

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://applymatic.ca

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Optional override (default: claude-sonnet-5)
ANTHROPIC_MODEL=claude-sonnet-5

# ── Stripe (use LIVE keys in production) ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Job search ───────────────────────────────────────────────────────────────
# Primary: RapidAPI JSearch (paid plan recommended for production)
JSEARCH_API_KEY=your_rapidapi_key_1
# Secondary JSearch key — used automatically when the first key quota is exhausted
JSEARCH_API_KEY_2=your_rapidapi_key_2
# Backup: Freehire public API (used when both JSearch keys are exhausted)
# FREEHIRE_API_BASE=https://freehire.dev/api/v1

# ── Contact & careers email (SMTP) ───────────────────────────────────────────
# Required for /contact and /careers form submissions.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM="Applymatic <info@applymatic.ca>"
